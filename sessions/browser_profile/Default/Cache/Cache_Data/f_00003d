function convertGuntasToAcres(gunta){
 var sum1 = 0;
 var a = gunta.split(".");
 sum1 = sum1 + (parseFloat(a[0])*40) + (parseFloat(a[1])/100);
 return Math.floor(sum1/40) + ((sum1%40)/100);
}

