function sumSubAcreGunta(valArr,operation)
{
		
	//var valArr = ['0.2','0.2','0.3']; 
	var val = 0;
	var acreInGuntaVal = 0;
	var guntaInVal = 0;
	var totalGunta = 0;
	var totalGuntaArr = [];
	
	for(var i=0; i<valArr.length; i++) {
		if(isNaN(valArr[i]))
			valArr[i] = 0;
		val = ''+parseFloat(valArr[i]).toFixed(4);
		acreInGuntaVal = parseInt(parseInt(val.split(".")[0])*40);
		guntaInVal = parseFloat(parseInt(val.split(".")[1])/100);
		totalGunta = parseInt(acreInGuntaVal) + parseFloat(guntaInVal);
		totalGuntaArr.push(totalGunta);
	}
	
	var totalGuntaSum = 0;
	    
	if(operation == 'sub') {
		totalGuntaSum = parseFloat(totalGuntaArr[0]) - parseFloat(totalGuntaArr[1]);
	}
	else {
		for(var i=0; i<totalGuntaArr.length; i++) {
			totalGuntaSum = parseFloat(totalGuntaSum) + parseFloat(totalGuntaArr[i]);
		}
	}
	 	 
	var newAcre = parseInt(totalGuntaSum/40);
	var newGunta = parseFloat(parseFloat(totalGuntaSum%40)/100);
	var ret = parseInt(newAcre) + newGunta;
	
	//alert(parseFloat(ret).toFixed(4));
	return parseFloat(ret).toFixed(4);
}


