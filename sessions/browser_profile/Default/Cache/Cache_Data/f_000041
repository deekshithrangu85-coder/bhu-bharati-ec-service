		alert('Enter valid aadhar number.');
		obj.value = "";
		return false;
	}
	if (flgVal) {
		alert('Enter valid aadhar number.');
		obj.value = "";
		return false;
	}
	if (strVal.verhoeffCheck() == false) {
		alert('Enter valid aadhar number.');
		obj.value = "";
		return false;
	}
}

