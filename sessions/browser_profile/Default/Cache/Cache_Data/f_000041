function mobileverification(e,altorMob,id) {
	
	var mobilelen = document.getElementById(id).value;
	var key;
	var keychar;

	if (window.event)
		key = window.event.keyCode;
	else if (e)
		key = e.which;
	else
		return true;
	keychar = String.fromCharCode(key);
	keychar = keychar.toLowerCase();
	// control keys
	if ((key == null) || (key == 0) || (key == 8)
			|| (key == 9) || (key == 13) || (key == 27)) {
		return true;
	}

	// alphas and numbers
	else if ((("0123456789").indexOf(keychar) > -1)) {
		if (mobilelen.length < 1) {
			if ((keychar == 0)) {
				if(altorMob=='alt'){
				alert("Alternate Mobile No. must not start with 0");
				document.getElementById(id).value="";
				return false;
				}
				if(altorMob=='mobile'){
					alert("Mobile No. must not start with 0");
					document.getElementById(id).value="";
					return false;
				}
			}
