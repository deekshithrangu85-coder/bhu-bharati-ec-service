function validatefileForCertifiedCC(input){
	
    var max_length = 2097152; 
	imageVal = document.getElementById(input).value.split('.');
	
	var ext = imageVal[imageVal.length - 1].toLowerCase();
    if ( (ext != 'jpeg')
			 && (ext != 'pdf')) {
		alert("Please Upload jpeg,pdf file only.");
		document.getElementById(input).value = "";
		return false;
	}
	var filesize = (document.getElementById(input).files[0].size);
	if (filesize > max_length) {

		alert("File Size cannot be greater than 2 MB.");
		
		document.getElementById(input).value = "";
		
		return false;
	}
	
}
function checkForAlphaNumeric(value,id){
	
	if( /[^a-zA-Z0-9\-\/]/.test(value) ) {
        $('#'+id).val('');
        return false;
    }
    return true;   
}
