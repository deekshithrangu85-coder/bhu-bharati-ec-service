	 function convertGuntasToAcresDcSumSubInventory(val1, val2, operation){
	     	val1 = ''+parseFloat(val1).toFixed(4);
	     	val2 = ''+parseFloat(val2).toFixed(4);
	     	
	     	//val1 = ''+parseFloat(val1);
	     	//val2 = ''+parseFloat(val2);
	     	 //var sum1 = 0;
	     	 //changes made;
	     	 var acreInGuntaVal1 = parseInt(parseInt(val1.split(".")[0])*40);
	     	 var guntaInVal1 = parseFloat(parseInt(val1.split(".")[1])/100);
	     	 var totalGunta1 = parseInt(acreInGuntaVal1) + parseFloat(guntaInVal1);
	     	 
	     	 var acreInGuntaVal2 = parseInt(parseInt(val2.split(".")[0])*40);
	    	 var guntaInVal2 = parseFloat(parseInt(val2.split(".")[1])/100);
	     	 var totalGunta2 = parseInt(acreInGuntaVal2) + parseFloat(guntaInVal2);
	     	 
	     	var totalGuntaSum = 0;
	     	 if(operation == 'sum')
	     		 totalGuntaSum = parseFloat(totalGunta1) + parseFloat(totalGunta2);
	     	 
	     	 if(operation == 'sub')
	     		 totalGuntaSum = parseFloat(totalGunta1) - parseFloat(totalGunta2);
	     	 
	     	 var newAcre = parseInt(totalGuntaSum/40);
	     	 var newGunta = parseFloat(parseFloat(totalGuntaSum%40)/100);
	     	 
	     	 var ret = parseInt(newAcre) + newGunta;
	     	 
	     	//FLOOR(p_guntas/40)::INT + ROUND((p_guntas%40)/100,4)
	     	 return parseFloat(ret).toFixed(4);
	     	//return Math.floor(newAcre/40) + ((newGunta%40)/100);
	     }  
	 
	 
